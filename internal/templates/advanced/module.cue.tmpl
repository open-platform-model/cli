// Package {{.PackageName}} defines the {{.ModuleName}} module.
// This is an advanced multi-package module with:
// - module.cue: metadata and #config schema (with defaults)
// - components.cue: component composition
// - components/: component templates (subpackage)
package {{.PackageName}}

import (
	m "opmodel.dev/core/module@v1"
	"opmodel.dev/schemas@v1"
)

// Module definition
m.#Module

// #workloadComponent is the name of the primary workload component in this module.
#workloadComponent: "web"

// Module metadata
metadata: {
	modulePath:  "{{.ModulePath}}"
	name:        "{{.ModuleName}}"
	version:     "{{.Version}}"
	description: string | *"An advanced OPM module with multi-package architecture"
	defaultNamespace: "default"
}

// Components are defined in components.cue

// #config defines the configuration schema with defaults.
// Override fields at deploy time via: opm mod apply -f my-values.cue .
#config: {
	// Web frontend configuration
	web: {
		image: schemas.#Image & {
			repository: string | *"nginx"
			tag:        string | *"latest"
			digest:     string | *""
		}
		scaling: int & >=1 | *2
		port:    int & >0 & <=65535 | *8080
	}

	// API backend configuration
	api: {
		image: schemas.#Image & {
			repository: string | *"node"
			tag:        string | *"20-alpine"
			digest:     string | *""
		}
		scaling: int & >=1 | *3
		port:    int & >0 & <=65535 | *3000
	}

	// Worker configuration
	worker: {
		image: schemas.#Image & {
			repository: string | *"python"
			tag:        string | *"3.12-alpine"
			digest:     string | *""
		}
		scaling: int & >=1 | *2
	}

	// Database configuration
	db: {
		image: schemas.#Image & {
			repository: string | *"postgres"
			tag:        string | *"16-alpine"
			digest:     string | *""
		}
		storageSize: string | *"10Gi"
		port:        int & >0 & <=65535 | *5432
	}

	securityContext?: schemas.#SecurityContextSchema
}

debugValues: {
	web: {
		image: {
			repository: "nginx"
			tag:        "latest"
			digest:     ""
		}
		scaling: 2
		port:    8080
	}
	api: {
		image: {
			repository: "node"
			tag:        "20-alpine"
			digest:     ""
		}
		scaling: 3
		port:    3000
	}
	worker: {
		image: {
			repository: "python"
			tag:        "3.12-alpine"
			digest:     ""
		}
		scaling: 2
	}
	db: {
		image: {
			repository: "postgres"
			tag:        "16-alpine"
			digest:     ""
		}
		storageSize: "10Gi"
		port:        5432
	}
}
