// Package main defines the {{.ModuleName}} module.
// This is an advanced multi-package module with:
// - module.cue: metadata and schema
// - components.cue: component composition
// - values.cue: default values
// - components/: component templates (subpackage)
package main

import (
	"opmodel.dev/core@v1"
	"opmodel.dev/schemas@v1"
)

// Module definition
core.#Module

// Module metadata
metadata: {
	modulePath:  "{{.ModulePath}}"
	name:        "{{.ModuleName}}"
	version:     "{{.Version}}"
	description: string | *"An advanced OPM module with multi-package architecture"
	defaultNamespace: "default"
}

// Components are defined in components.cue

// #config defines the configuration schema for this module.
#config: {
	// Web frontend configuration
	web: {
		image!:   schemas.#Image
		scaling?: int & >=1
		port?:    int & >0 & <=65535
	}

	// API backend configuration
	api: {
		image!:   schemas.#Image
		scaling?: int & >=1
		port?:    int & >0 & <=65535
	}

	// Worker configuration
	worker: {
		image!:   schemas.#Image
		scaling?: int & >=1
	}

	// Database configuration
	db: {
		image!:       schemas.#Image
		storageSize?: string
		port?:        int & >0 & <=65535
	}
}
