// Database component template with persistent storage.
package components

import (
	resources_workload "opmodel.dev/resources/workload@v1"
	resources_storage "opmodel.dev/resources/storage@v1"
)

// #db is a reusable database component template.
#db: {
	metadata: labels: "core.opmodel.dev/workload-type": "stateful"

	resources_workload.#Container
	resources_storage.#Volumes

	spec: {
		container: {
			name:  "db"
			image: _
			ports: db: {
				targetPort: 5432
			}
			resources: {
				requests: {
					cpu:    "200m"
					memory: "512Mi"
				}
				limits: {
					cpu:    "1000m"
					memory: "2Gi"
				}
			}
			volumeMounts: [{
				name:      "data"
				mountPath: "/var/lib/postgresql/data"
			}]
		}
		volumes: data: persistentClaim: {
			size: string | *"10Gi"
		}
	}
}
