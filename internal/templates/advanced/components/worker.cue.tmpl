// Worker component template for background jobs.
package components

import (
	resources_workload "opmodel.dev/resources/workload@v1"
	traits_workload "opmodel.dev/traits/workload@v1"
)

// #worker is a reusable background worker component template.
#worker: {
	metadata: labels: "core.opmodel.dev/workload-type": "stateless"

	resources_workload.#Container
	traits_workload.#Scaling

	spec: {
		container: {
			name:  "worker"
			image: _
			resources: {
				requests: {
					cpu:    "100m"
					memory: "256Mi"
				}
				limits: {
					cpu:    "500m"
					memory: "512Mi"
				}
			}
		}
		scaling: count: int | *2
	}
}
