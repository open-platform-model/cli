// Values provide concrete configuration for the module.
// These satisfy the #config schema defined in module.cue.
package main

values: {
	// Web frontend configuration
	web: {
		image: {
			repository: "nginx"
			tag:        "latest"
			digest:     ""
		}
		scaling: 2
		port:    8080
	}

	// API backend configuration
	api: {
		image: {
			repository: "node"
			tag:        "20-alpine"
			digest:     ""
		}
		scaling: 3
		port:    3000
	}

	// Background worker configuration
	worker: {
		image: {
			repository: "python"
			tag:        "3.12-alpine"
			digest:     ""
		}
		scaling: 2
	}

	// Database configuration
	db: {
		image: {
			repository: "postgres"
			tag:        "16-alpine"
			digest:     ""
		}
		storageSize: "10Gi"
		port:        5432
	}
}
