// Package {{.PackageName}} defines the {{.ModuleName}} module.
// This is a standard module with separated concerns:
// - module.cue: metadata and #config schema (with defaults)
// - components.cue: component definitions
package {{.PackageName}}

import (
	m "opmodel.dev/core/module@v1"
	"opmodel.dev/schemas@v1"
)

// Module definition
m.#Module

// #workloadComponent is the name of the primary workload component in this module.
#workloadComponent: "web"

// Module metadata
metadata: {
	modulePath:  "{{.ModulePath}}"
	name:        "{{.ModuleName}}"
	version:     "{{.Version}}"
	description: string | *"A standard OPM module"
	defaultNamespace: "default"
}

// Components are defined in components.cue

// #config defines the configuration schema with defaults.
// Override fields at deploy time via: opm mod apply -f my-values.cue .
#config: {
	// Web component configuration
	web: {
		// Container image
		image: schemas.#Image & {
			repository: string | *"nginx"
			tag:        string | *"latest"
			digest:     string | *""
		}

		// Number of replicas
		scaling: int & >=1 | *2

		// Port to expose
		port: int & >0 & <=65535 | *8080
	}

	// API component configuration
	api: {
		// Container image
		image: schemas.#Image & {
			repository: string | *"node"
			tag:        string | *"20-alpine"
			digest:     string | *""
		}

		// Number of replicas
		scaling: int & >=1 | *2

		// Port to expose
		port: int & >0 & <=65535 | *3000
	}

	// Shared security context applied when enabled.
	securityContext?: schemas.#SecurityContextSchema
}

debugValues: {
	web: {
		image: {
			repository: "nginx"
			tag:        "latest"
			digest:     ""
		}
		scaling: 2
		port:    8080
	}
	api: {
		image: {
			repository: "node"
			tag:        "20-alpine"
			digest:     ""
		}
		scaling: 2
		port:    3000
	}
}
