{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "external_directory": {
            "~/Dev/open-platform-model/local/**": "allow",
            "~/Dev/open-platform-model/catalog/**": "allow",
            "~/Dev/open-platform-model/opm/**": "allow",
            "~/Dev/open-platform-model/poc-controller/**": "allow",
            "~/Dev/open-platform-model/opmodel.dev/**": "allow",
            "../local/**": "allow",
            "../catalog/**": "allow",
            "../opm/**": "allow",
            "../poc-controller/**": "allow",
            "../opmodel.dev/**": "allow"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.envrc": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    }
}